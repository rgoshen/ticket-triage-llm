# Ollama endpoint — the openai client base URL
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model to use (no default — must be set)
# OLLAMA_MODEL=qwen3.5:4b

# Sampling parameters are NOT configurable via env.
# They are module-level constants in config.py (temperature=0.2, top_p=0.9,
# top_k=40, repetition_penalty=1.0). Changing them requires a decision-log entry.

# SQLite database path (relative to project root)
DB_PATH=data/traces.db

# Logging level
LOG_LEVEL=INFO
